# Copy to .env and adjust for your environment.
# Vite only exposes variables prefixed with VITE_ to client code.

# Flask API base (no trailing slash, no /api suffix — that's added in code)
VITE_API_URL=https://thinkeasy-1-0.onrender.com/api

# Optional analytics (leave blank to disable — see src/services/analytics.js)
VITE_GA_MEASUREMENT_ID=
VITE_CLARITY_PROJECT_ID=
